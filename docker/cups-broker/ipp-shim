#!/usr/bin/env python3
"""
ipp-shim — middleware IPP transparent qui absorbe l'op Microsoft 0x4000
("windows-ext") et proxifie tout le reste vers cupsd.

Pourquoi : les Microsoft IPP Class Drivers (PWG Raster, PCL6, PS) de Windows
11 envoient une opération IPP propriétaire 0x4000 après Get-Printer-Attributes
pour récupérer un driver vendor. CUPS ne sait pas la traiter (op-id hors plage
publique), répond client-error-bad-request, et Windows abandonne l'install
avec ERROR_INVALID_PRINTER_STATE (0x000003fa).

Ce shim intercepte uniquement l'op 0x4000 et y répond `successful-ok` avec un
groupe d'attributs minimal (charset + natural-language), ce qui satisfait
Windows. Toutes les autres opérations (Get-Printer-Attributes, Print-Job,
Create-Job, Send-Document, Validate-Job, etc.) sont forwardées telles quelles
vers cupsd qui écoute sur 127.0.0.1:6310.

Pas de dépendance hors stdlib (python3 + http.server + http.client + struct).
Threadé pour gérer plusieurs clients simultanés.

IPP message layout (RFC 8011 §4.1) :
  0-1 : version-number (major, minor — uint8 chacun)
  2-3 : operation-id (request) ou status-code (response) — uint16 BE
  4-7 : request-id — uint32 BE
  8-… : attribute groups (delimiter tags + attributes), terminé par 0x03
"""
import http.client
import http.server
import logging
import signal
import socketserver
import struct
import sys

UPSTREAM_HOST = "127.0.0.1"
UPSTREAM_PORT = 6310
LISTEN_HOST = "0.0.0.0"
LISTEN_PORT = 6311
UPSTREAM_TIMEOUT = 300  # secondes — couvre les uploads de gros PDF

# Op-id Microsoft à intercepter. Big-endian uint16 = b'\x40\x00'.
WINDOWS_EXT_OP_ID = 0x4000

# Headers à ne pas re-propager (calculés par http.client lui-même ou
# spécifiques au hop client→shim).
HOP_HEADERS = {"host", "connection", "content-length", "transfer-encoding",
               "keep-alive", "proxy-authenticate", "proxy-authorization",
               "te", "trailers", "upgrade"}

logging.basicConfig(
    level=logging.INFO,
    format="[ipp-shim] %(asctime)s %(message)s",
    datefmt="%Y-%m-%dT%H:%M:%S",
    stream=sys.stdout,
)
log = logging.getLogger("ipp-shim")


def build_successful_ok(version_bytes: bytes, request_id: int) -> bytes:
    """
    Réponse IPP minimale `successful-ok` (status 0x0000) avec uniquement
    le groupe operation-attributes (charset + natural-language) — le strict
    minimum pour qu'un client IPP considère la réponse valide.

    Format : version (2) + status (2) + request-id (4) + 0x01 (op-attr tag)
             + attribute "attributes-charset" (charset value-tag 0x47)
             + attribute "attributes-natural-language" (naturalLanguage 0x48)
             + 0x03 (end-of-attributes)
    """
    def attr(value_tag: int, name: bytes, value: bytes) -> bytes:
        return (struct.pack(">B H", value_tag, len(name)) + name
                + struct.pack(">H", len(value)) + value)

    body = b""
    body += version_bytes                               # version (echo de la requête)
    body += struct.pack(">H", 0x0000)                   # status-code successful-ok
    body += struct.pack(">I", request_id)               # request-id (echo)
    body += b"\x01"                                     # operation-attributes-tag
    body += attr(0x47, b"attributes-charset", b"utf-8")
    body += attr(0x48, b"attributes-natural-language", b"en-us")
    body += b"\x03"                                     # end-of-attributes-tag
    return body


class IppShimHandler(http.server.BaseHTTPRequestHandler):
    # Désactiver le buffering server-side ; les jobs IPP peuvent être lourds.
    protocol_version = "HTTP/1.1"
    # Évite les logs verbeux par défaut (un par requête) — on logue
    # explicitement les events intéressants.
    def log_message(self, fmt, *args):
        pass

    def do_POST(self):
        ctype = self.headers.get("Content-Type", "")
        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            length = 0

        body = self.rfile.read(length) if length > 0 else b""

        # Détection IPP : Content-Type application/ipp ET payload >= 8 octets
        # (header IPP minimal). Sinon on proxifie tel quel.
        if ctype.startswith("application/ipp") and len(body) >= 8:
            op_id = struct.unpack(">H", body[2:4])[0]
            if op_id == WINDOWS_EXT_OP_ID:
                request_id = struct.unpack(">I", body[4:8])[0]
                resp = build_successful_ok(body[0:2], request_id)
                log.info("absorbed windows-ext (0x4000) request-id=%d path=%s",
                         request_id, self.path)
                self.send_response(200)
                self.send_header("Content-Type", "application/ipp")
                self.send_header("Content-Length", str(len(resp)))
                self.send_header("Connection", "close")
                self.end_headers()
                self.wfile.write(resp)
                return

        # Toutes les autres requêtes : proxy transparent vers cupsd.
        self._proxy_to_cupsd(body)

    # GET, PUT, DELETE, etc. : proxy direct (CUPS sert l'icône, le PPD, etc.)
    def do_GET(self):     self._proxy_to_cupsd(b"")
    def do_HEAD(self):    self._proxy_to_cupsd(b"")
    def do_PUT(self):
        length = int(self.headers.get("Content-Length", "0"))
        self._proxy_to_cupsd(self.rfile.read(length) if length else b"")
    def do_DELETE(self):  self._proxy_to_cupsd(b"")
    def do_OPTIONS(self): self._proxy_to_cupsd(b"")

    def _proxy_to_cupsd(self, body: bytes):
        try:
            conn = http.client.HTTPConnection(
                UPSTREAM_HOST, UPSTREAM_PORT, timeout=UPSTREAM_TIMEOUT)
            conn.putrequest(self.command, self.path, skip_host=True,
                            skip_accept_encoding=True)
            for k, v in self.headers.items():
                if k.lower() not in HOP_HEADERS:
                    conn.putheader(k, v)
            conn.putheader("Host", f"{UPSTREAM_HOST}:{UPSTREAM_PORT}")
            conn.putheader("Content-Length", str(len(body)))
            conn.putheader("Connection", "close")
            conn.endheaders(message_body=body)
            resp = conn.getresponse()
            resp_body = resp.read()
            self.send_response(resp.status, resp.reason)
            for k, v in resp.getheaders():
                if k.lower() not in HOP_HEADERS:
                    self.send_header(k, v)
            self.send_header("Content-Length", str(len(resp_body)))
            self.send_header("Connection", "close")
            self.end_headers()
            self.wfile.write(resp_body)
            conn.close()
        except Exception as e:
            log.error("proxy error %s %s: %s", self.command, self.path, e)
            self.send_error(502, f"upstream error: {e}")


class ThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True


def main():
    server = ThreadingServer((LISTEN_HOST, LISTEN_PORT), IppShimHandler)

    def shutdown(signum, _frame):
        log.info("received signal %d, shutting down", signum)
        server.shutdown()

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    log.info("listening on %s:%d, proxying to cupsd at %s:%d",
             LISTEN_HOST, LISTEN_PORT, UPSTREAM_HOST, UPSTREAM_PORT)
    server.serve_forever()
    log.info("stopped")


if __name__ == "__main__":
    main()
