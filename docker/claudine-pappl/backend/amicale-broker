#!/usr/bin/env python3
"""
Backend job-processing pour Claudine, invoqué par le binaire PAPPL `claudine`
(via popen) à chaque IPP Print-Job. Compatible argv/env vars avec l'ancienne
invocation par cupsd — le code interne est strictement identique, seul le
parent qui le spawne a changé (PAPPL au lieu de cupsd).

Le binaire C l'invoque avec argv :
    argv[0] = chemin du script
    argv[1] = job-id (PAPPL job-id, format string)
    argv[2] = user (username IPP fourni par le client, depuis Basic auth)
    argv[3] = title (job-name attribut IPP)
    argv[4] = copies
    argv[5] = options (key=value pairs séparés par espaces : print-color-mode,
                       sides, etc. — formattés à l'identique de CUPS)
    argv[6] = filename du spool PDF (PAPPL convertit toujours en PDF avant
              d'invoquer ce backend, donc argv[6] est garanti présent)

Variables d'env utiles :
    AUTH_PASSWORD       = le print_token (mot de passe Basic auth)
    AUTH_USERNAME       = email/username IPP (pour audit)
    PRINTER             = nom de la queue (cosmétique)
    AMICALE_*           = vars métier persistées dans /etc/claudine/amicale.env
                          (lu si PassEnv ne propage pas — voir _load_amicale_env_file)

Codes de sortie (héritage CUPS, le binaire PAPPL les translate vers les
statuts de job PAPPL) :
    0 = OK                          → COMPLETED
    1 = CUPS_BACKEND_FAILED         → ABORTED (erreur définitive)
    2 = CUPS_BACKEND_AUTH_REQUIRED  → ABORTED + log "auth"
    3 = CUPS_BACKEND_HOLD           → HELD
    4 = CUPS_BACKEND_STOP           → ABORTED (quota épuisé)
    5 = CUPS_BACKEND_CANCEL         → CANCELED
    6 = CUPS_BACKEND_RETRY_CURRENT_JOB → PENDING (PAPPL retentera)

Flux :
    1. Lecture spool + paramètres
    2. pdfinfo → nombre de pages
    3. POST /api/v1/print/submit  → {jobId, creditsCost}
    4. Connexion socket Kyocera → header PJL + bytes du PDF + footer
    5. POST /api/v1/print/{jobId}/complete  (ou /error en cas d'échec étape 4)
"""
import os
import re
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request
import json

# Codes CUPS
CUPS_BACKEND_OK                 = 0
CUPS_BACKEND_FAILED             = 1
CUPS_BACKEND_AUTH_REQUIRED      = 2
CUPS_BACKEND_STOP               = 4
CUPS_BACKEND_RETRY_CURRENT_JOB  = 6

LOG = sys.stderr  # CUPS capture stderr dans error_log

def log(level: str, msg: str) -> None:
    # Le préfixe "DEBUG:" / "INFO:" / "ERROR:" est interprété par CUPS pour le
    # niveau dans error_log et pour la zone "État" affichée au user.
    print(f"{level}: claudine: {msg}", file=LOG, flush=True)

# ─── Args ──────────────────────────────────────────────────────────────────
# PAPPL invoque toujours avec argv[1..6] complets. La convention argv-vide
# (legacy CUPS discovery) n'est pas utilisée par PAPPL et a donc été retirée.
if len(sys.argv) < 7:
    log("ERROR", f"argv inattendu (got {len(sys.argv)} args, expected 7)")
    sys.exit(CUPS_BACKEND_FAILED)

job_id      = sys.argv[1]
ipp_user    = sys.argv[2]                       # username IPP, sert à la traçabilité
job_title   = sys.argv[3]
copies      = max(1, int(sys.argv[4] or "1"))
options_str = sys.argv[5]
spool_path  = sys.argv[6]                       # PAPPL fournit toujours un chemin

# PAPPL passe le print_token via AUTH_PASSWORD (Basic auth). On garde le
# fallback AUTH_INFO_PASSWORD pour compat avec d'éventuels callers historiques.
print_token = (
    os.environ.get("AUTH_PASSWORD", "").strip()
    or os.environ.get("AUTH_INFO_PASSWORD", "").strip()
)
ipp_user_from_basic_auth = os.environ.get("AUTH_USERNAME", "").strip()

# Le binaire PAPPL passe les vars via execve, donc l'env arrive normalement.
# On garde quand même la lecture de fichier en filet de sécurité (utile en
# debug ou si quelqu'un lance le script à la main pour tester). Le fichier
# est écrit par l'entrypoint.sh au démarrage du container.
def _load_amicale_env_file(path: str = "/etc/claudine/amicale.env") -> None:
    if not os.path.isfile(path):
        return
    try:
        with open(path, "r") as f:
            for line in f:
                line = line.strip()
                if not line or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                k = k.strip()
                if k.startswith("AMICALE_") and k not in os.environ:
                    os.environ[k] = v.strip()
    except OSError:
        pass

_load_amicale_env_file()

app_url     = os.environ.get("AMICALE_APP_URL",    "http://127.0.0.1:8081").rstrip("/")
broker_key  = os.environ.get("AMICALE_PRINT_BROKER_KEY", "").strip()
printer_host = os.environ.get("AMICALE_PRINTER_HOST", "192.168.1.10")
printer_port = int(os.environ.get("AMICALE_PRINTER_PORT", "9100"))

if not print_token:
    log("ERROR", "pas de password fourni — auth requis")
    sys.exit(CUPS_BACKEND_AUTH_REQUIRED)

if not broker_key:
    log("ERROR", "AMICALE_PRINT_BROKER_KEY non configuré dans l'env du container")
    sys.exit(CUPS_BACKEND_FAILED)

# ─── Spool : si CUPS l'a passé en argv, le fichier est déjà là.
#     Sinon, le PDF arrive sur stdin → il faut le buffériser sur disque pour
#     pouvoir le passer à pdfinfo (qui lit un path) puis le streamer ensuite.
if spool_path and os.path.exists(spool_path):
    pdf_path = spool_path
    cleanup_pdf = False
else:
    import tempfile
    fd, pdf_path = tempfile.mkstemp(prefix="claudine-", suffix=".pdf")
    with os.fdopen(fd, "wb") as f:
        while True:
            chunk = sys.stdin.buffer.read(64 * 1024)
            if not chunk: break
            f.write(chunk)
    cleanup_pdf = True

def cleanup() -> None:
    if cleanup_pdf:
        try: os.unlink(pdf_path)
        except OSError: pass

# ─── Parse options IPP ────────────────────────────────────────────────────
# Exemples : "print-color-mode=color sides=two-sided-long-edge"
def opt(name: str, default: str = "") -> str:
    m = re.search(rf"\b{re.escape(name)}=(\S+)", options_str)
    return m.group(1) if m else default

color_mode = opt("print-color-mode", "monochrome")
sides      = opt("sides", "one-sided")

is_color  = color_mode.lower().startswith("color")
is_duplex = sides.startswith("two-sided")

log("DEBUG", f"job_id={job_id} user={ipp_user} title={job_title!r} "
              f"copies={copies} color={is_color} duplex={is_duplex} spool={pdf_path}")

# ─── Détection format ─────────────────────────────────────────────────────
# CUPS du broker est en queue raw (IPP Everywhere ne peut pas self-probe
# notre backend custom), donc le client envoie son format natif :
#   - macOS  → PostScript (ou PDF récent)
#   - Linux  → PDF
#   - Windows (driver Kyocera natif) → Prescribe+PJL+PCL — formats Kyocera
#     natifs, on passthrough sans transformation.
def detect_format(path: str) -> str:
    """Renvoie 'pdf', 'ps', 'pjl', ou 'unknown' selon les magic bytes."""
    try:
        with open(path, "rb") as f:
            head = f.read(64)
    except OSError:
        return "unknown"
    if head.startswith(b"%PDF-"):                                  return "pdf"
    if head.startswith(b"%!PS") or head.startswith(b"\x04%!"):     return "ps"
    # PJL Universal Exit Language, PJL direct, ou Prescribe Kyocera (préambule
    # `!R!…;EXIT;` que le driver Windows envoie pour reset l'imprimante avant
    # de basculer en PJL). Tous trois sont compris nativement par la Kyocera.
    if (b"\x1B%-12345X" in head or head.startswith(b"@PJL")
            or head.startswith(b"!R!") or head.startswith(b"\x1BE")):
        return "pjl"
    return "unknown"

fmt = detect_format(pdf_path)
log("DEBUG", f"format détecté : {fmt}")

if fmt == "ps":
    # Convertir en PDF avec Ghostscript. -dSAFER désactive les opérateurs
    # dangereux (lecture/écriture arbitraire). -dNOPAUSE / -dBATCH / -dQUIET
    # = mode non-interactif silencieux.
    converted = pdf_path + ".converted.pdf"
    try:
        subprocess.run(
            ["gs", "-sDEVICE=pdfwrite", "-dSAFER", "-dNOPAUSE", "-dBATCH",
             "-dQUIET", f"-sOutputFile={converted}", pdf_path],
            check=True, capture_output=True, text=True, timeout=120,
        )
    except subprocess.CalledProcessError as e:
        log("ERROR", f"gs PostScript→PDF a échoué (rc={e.returncode}): {e.stderr.strip()[:300]}")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
    except subprocess.TimeoutExpired:
        log("ERROR", "gs PostScript→PDF timeout")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
    if cleanup_pdf:
        try: os.unlink(pdf_path)
        except OSError: pass
    pdf_path = converted
    cleanup_pdf = True
    fmt = "pdf"
    log("INFO", "PostScript converti en PDF")
elif fmt == "unknown":
    log("ERROR", "format spool non reconnu (PDF/PS/PJL/PCL/Prescribe) — abort")
    cleanup(); sys.exit(CUPS_BACKEND_FAILED)

# ─── Comptage pages ───────────────────────────────────────────────────────
# Pour PDF : pdfinfo (précis). Pour PJL/PCL/Prescribe : on compte les form
# feeds (\x0C) — approximation correcte pour la quasi-totalité des drivers
# Windows. Si le compte ressort à 0 (cas d'un job qui ne trigger pas FF en
# fin de page), on retombe sur 1 plutôt que d'abort — sous-billing préférable
# à un faux échec.
if fmt == "pdf":
    try:
        res = subprocess.run(
            ["pdfinfo", pdf_path],
            check=True, capture_output=True, text=True, timeout=30,
        )
    except subprocess.CalledProcessError as e:
        log("ERROR", f"pdfinfo a échoué (rc={e.returncode}): {e.stderr.strip()}")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
    except subprocess.TimeoutExpired:
        log("ERROR", "pdfinfo timeout")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)

    m = re.search(r"^Pages:\s+(\d+)", res.stdout, re.MULTILINE)
    if not m:
        log("ERROR", f"pages introuvables dans pdfinfo output:\n{res.stdout}")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
    pages = int(m.group(1))
    if pages <= 0:
        log("ERROR", f"pages={pages} non valide")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
else:  # pjl
    try:
        with open(pdf_path, "rb") as f:
            ff_count = f.read().count(b"\x0C")
    except OSError as e:
        log("ERROR", f"lecture spool a échoué : {e}")
        cleanup(); sys.exit(CUPS_BACKEND_FAILED)
    pages = max(1, ff_count)
    log("DEBUG", f"PJL/PCL : {ff_count} form-feeds → {pages} pages estimées")

log("INFO", f"{pages} pages détectées")

# ─── HTTP helper ──────────────────────────────────────────────────────────
def post_json(path: str, payload: dict, retries: int = 1, timeout: float = 10.0):
    """POST JSON to coworker-app. Retourne (status, body_dict_or_None)."""
    body = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        f"{app_url}{path}",
        data=body,
        headers={
            "Content-Type":         "application/json",
            "X-Print-Broker-Key":   broker_key,
        },
        method="POST",
    )
    last_exc = None
    for attempt in range(retries + 1):
        try:
            with urllib.request.urlopen(req, timeout=timeout) as r:
                raw = r.read()
                return r.status, (json.loads(raw) if raw else None)
        except urllib.error.HTTPError as e:
            try:    err_body = json.loads(e.read())
            except Exception: err_body = None
            return e.code, err_body
        except (urllib.error.URLError, socket.timeout, OSError) as e:
            last_exc = e
            log("WARN", f"POST {path} attempt {attempt+1} échec : {e}")
            time.sleep(min(2 ** attempt, 8))
    log("ERROR", f"POST {path} a échoué après {retries+1} tentatives : {last_exc}")
    return None, None

# ─── Submit (auth + quota préflight + crée PrinterJob côté Spring) ────────
status, body = post_json("/api/v1/print/submit", {
    "token":             print_token,
    "pages":             pages,
    "filename":          job_title or "document",
    "copies":            copies,
    "color":             is_color,
    "duplex":            is_duplex,
    "submittedUsername": ipp_user_from_basic_auth or ipp_user,
})

if status == 401:
    log("ERROR", "token refusé par le coworker-app")
    cleanup(); sys.exit(CUPS_BACKEND_AUTH_REQUIRED)
if status == 402:
    err = (body or {}).get("message", "crédits insuffisants")
    log("ERROR", f"crédits insuffisants : {err}")
    cleanup(); sys.exit(CUPS_BACKEND_STOP)
if status == 422:
    err = (body or {}).get("message", "requête invalide")
    log("ERROR", f"requête refusée : {err}")
    cleanup(); sys.exit(CUPS_BACKEND_FAILED)
if status != 200:
    log("ERROR", f"submit failed status={status} body={body}")
    cleanup(); sys.exit(CUPS_BACKEND_RETRY_CURRENT_JOB)

server_job_id = (body or {}).get("jobId")
if not server_job_id:
    log("ERROR", f"pas de jobId dans la réponse: {body}")
    cleanup(); sys.exit(CUPS_BACKEND_FAILED)
log("INFO", f"server jobId={server_job_id} cost={body.get('creditsCost')} crédits")

# ─── Push PDF + PJL vers la Kyocera ───────────────────────────────────────
def sanitize_name(s: str) -> str:
    if not s: return "document"
    return re.sub(r'[^\x20-\x7E]', '_', s).replace('"', "'")

UEL = "\x1B%-12345X"
if fmt == "pdf":
    pjl_header = (
        UEL
        + f'@PJL JOB NAME="{sanitize_name(job_title)}"\r\n'
        + f'@PJL SET COPIES={copies}\r\n'
        + f'@PJL SET DUPLEX={"ON" if is_duplex else "OFF"}\r\n'
        + ("@PJL SET BINDING=LONGEDGE\r\n" if is_duplex else "")
        + "@PJL ENTER LANGUAGE=PDF\r\n"
    ).encode("ascii")
    pjl_footer = ("\r\n" + UEL + "@PJL EOJ\r\n" + UEL).encode("ascii")
else:
    # Spool natif Kyocera (Prescribe / PJL / PCL — typiquement driver Windows).
    # Il porte déjà son propre `@PJL JOB`, son `@PJL SET COPIES/DUPLEX/...` et
    # son `@PJL ENTER LANGUAGE=...`. Wrapper additionnel = doublon qui peut
    # corrompre la job state ou se faire ignorer. Passthrough direct.
    # Conséquence : copies/duplex côté billing IPP peuvent diverger de ce que
    # le driver Windows a réellement encodé — on accepte (sous-billing > échec).
    pjl_header = b""
    pjl_footer = b""

def report_error(msg: str) -> None:
    s, _ = post_json(f"/api/v1/print/{server_job_id}/error",
                     {"message": msg[:500]}, retries=2, timeout=5.0)
    log("DEBUG" if s == 204 else "WARN",
        f"reported error to coworker-app : status={s}")

try:
    log("DEBUG", f"connexion à {printer_host}:{printer_port}")
    with socket.create_connection((printer_host, printer_port), timeout=5.0) as sk:
        sk.settimeout(120.0)
        sk.sendall(pjl_header)
        with open(pdf_path, "rb") as f:
            while True:
                chunk = f.read(64 * 1024)
                if not chunk: break
                sk.sendall(chunk)
        sk.sendall(pjl_footer)
    log("INFO", f"PDF poussé vers {printer_host}:{printer_port} ({pages}p × {copies})")
except (socket.error, OSError) as e:
    msg = f"impossible d'atteindre la Kyocera ({printer_host}:{printer_port}) : {e}"
    log("ERROR", msg)
    report_error(msg)
    cleanup(); sys.exit(CUPS_BACKEND_FAILED)

# ─── Marquer le job COMPLETED côté coworker-app ───────────────────────────
status, _ = post_json(f"/api/v1/print/{server_job_id}/complete", {}, retries=3, timeout=5.0)
if status != 204:
    # Le print physique a réussi mais le ledger ne s'est pas mis à jour.
    # CUPS_BACKEND_RETRY_CURRENT_JOB ferait réimprimer — pas ce qu'on veut.
    # On loggue fort et on quitte OK : le member ne sera pas débité, c'est un
    # cadeau accidentel mieux qu'un double-print. À détecter via dashboard.
    log("ERROR", f"PRINT OK mais /complete a échoué (status={status}, jobId={server_job_id}). "
                  f"Le membre n'a PAS été débité — corriger manuellement.")

cleanup()
log("INFO", f"job {server_job_id} terminé OK")
sys.exit(CUPS_BACKEND_OK)
