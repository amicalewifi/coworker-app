# Copy to ../.env at the compose project root and fill in real values.
# (.env is gitignored via *.env in .gitignore.)

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=amicale_wifi
POSTGRES_USER=amicale
POSTGRES_PASSWORD=change-me-strong-password

# --- pgAdmin (only reachable via 127.0.0.1:5050, e.g. SSH tunnel) -------------
PGADMIN_DEFAULT_EMAIL=admin@amicalewifi.ch
PGADMIN_DEFAULT_PASSWORD=change-me-strong-password

# --- Databasus backup user -----------------------------------------------------
# Provisioned by Flyway migration V13__databasus_role.sql via placeholder
# substitution. Use a dedicated, strong password — Databasus stores it.
DATABASUS_PWD=change-me-strong-password

# --- Spring secrets ------------------------------------------------------------
# Spring Boot relaxed binding maps these env vars to amicale.* keys, overriding
# the CHANGE_ME defaults baked into application.yml at runtime.
AMICALE_AKUVOX_API_KEY=
AMICALE_AKUVOX_DEVICE_PASS=
AMICALE_UNIFI_API_KEY=
AMICALE_ZAHLS_INSTANCE=
AMICALE_ZAHLS_API_KEY=

# --- Public URLs (used by Zahls callbacks) -------------------------------------
AMICALE_ZAHLS_SUCCESS_URL=https://coworker.amicalewifi.ch/mobile/?renewed=ok
AMICALE_ZAHLS_CANCEL_URL=https://coworker.amicalewifi.ch/mobile/
AMICALE_ZAHLS_PRINT_SUCCESS_URL=https://coworker.amicalewifi.ch/mobile/print?bought=ok
AMICALE_ZAHLS_PRINT_CANCEL_URL=https://coworker.amicalewifi.ch/mobile/print
AMICALE_ZAHLS_CONF_SUCCESS_URL=https://coworker.amicalewifi.ch/mobile/rooms?bought=ok
AMICALE_ZAHLS_CONF_CANCEL_URL=https://coworker.amicalewifi.ch/mobile/rooms
