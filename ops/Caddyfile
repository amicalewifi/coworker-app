{
    email hello@amicalewifi.ch
}

coworker.amicalewifi.ch {
    encode gzip
    reverse_proxy app:8081 {
        # During a deploy the `app` container is briefly unreachable while it
        # restarts (~25s). Instead of returning 502s to users, Caddy holds the
        # request for up to 45s, retrying the upstream every 500ms until it
        # answers. The user sees a slow page load instead of an error.
        lb_try_duration 45s
        lb_try_interval 500ms
    }
}

# Imprimante virtuelle Claudine — binaire PAPPL `claudine` tourne sur le host
# (network_mode: host, port 8000) pour atteindre wg0 → Kyocera et pour
# broadcaster du mDNS sur l'interface du host. Caddy termine TLS et
# reverse-proxy vers le gateway du bridge du projet (172.18.0.1, subnet pinné
# dans docker-compose.yml).
#
# IPPS a son port standard à 631 (RFC 8011) — macOS/Linux utilisent
# `ipps://print.amicalewifi.ch/printers/claudine` (port 631 par défaut).
# Windows (Microsoft IPP Class Driver) utilise `https://` sans port, ce qui
# résout sur 443 — on écoute donc les deux.
# Pour debug en CLI : `curl https://print.amicalewifi.ch:631/ipp/print`.

(print_claudine) {
    encode gzip
    request_body {
        max_size 500MB
    }
    # PAPPL expose ses imprimantes à `/ipp/print/<nom>`. Les clients (et
    # surtout les installs existantes macOS) utilisent l'URL legacy CUPS
    # `/printers/<nom>` documentée depuis le début. On rewrite côté Caddy
    # pour garder cette URL stable côté users — sinon ils devraient tous
    # supprimer + réinstaller leur imprimante.
    rewrite /printers/claudine /ipp/print/claudine

    # 8000 = binaire claudine (PAPPL) en host networking. Voir
    # docker/claudine-pappl/claudine.c.
    reverse_proxy 172.18.0.1:8000 {
        # PAPPL / IPP attendent HTTP/1.1 chunked — pas de HTTP/2.
        transport http {
            versions 1.1
        }
    }
}

# Port 443 — Windows (https:// sans port explicite)
print.amicalewifi.ch {
    import print_claudine
}

# Port 631 — macOS / Linux / iOS (ipps:// ou https://:631)
https://print.amicalewifi.ch:631 {
    import print_claudine
}
