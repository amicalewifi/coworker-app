{
    email hello@amicalewifi.ch
}

coworker.amicalewifi.ch {
    encode gzip
    reverse_proxy app:8081 {
        # During a deploy the `app` container is briefly unreachable while it
        # restarts (~25s). Instead of returning 502s to users, Caddy holds the
        # request for up to 45s, retrying the upstream every 500ms until it
        # answers. The user sees a slow page load instead of an error.
        lb_try_duration 45s
        lb_try_interval 500ms
    }
}

# Trampoline pour la capture de MAC du portail captif UniFi.
#
# Quand un client logged-out arrive directement sur coworker.amicalewifi.ch
# (qui est dans le walled-garden, donc jamais intercepté par UniFi),
# RootController 302 le navigateur vers http://10.0.1.2/coworker. 10.0.1.2 est
# l'IP côté tunnel WireGuard de ce VPS, joignable depuis le LAN coworking via
# le routeur Swisscom + WG. UniFi voit alors un client non autorisé essayer
# d'atteindre une IP hors walled-garden et 302 vers
# /guest/s/default/?id=<MAC>&... — on capture la MAC via CaptivePortalParamFilter.
#
# HTTP volontairement : UniFi n'intercepte pas le HTTPS vers les hôtes hors
# walled-garden (il bloquerait au niveau TCP). Le 302 HTTP est le seul
# mécanisme d'interception fiable côté UniFi.
#
# Filet de sécurité : si UniFi rate l'intercept (très rare), le paquet flue
# via le tunnel WG jusqu'ici. Caddy sert alors une 302 vers /login?tried=1,
# qui rend une page d'erreur explicite ("appareil non détecté") plutôt
# qu'une connexion refusée.
http://10.0.1.2 {
    redir /coworker https://coworker.amicalewifi.ch/login?tried=1 302
    respond 404
}

# Imprimante virtuelle Claudine — claudine-proxy (Go) tourne sur le host
# (network_mode: host, port 8000) pour atteindre wg0 → Kyocera. Caddy termine
# TLS et reverse-proxy vers le gateway du bridge du projet (172.18.0.1,
# subnet pinné dans docker-compose.yml). claudine-proxy authentifie le
# client puis forwarde le job IPP en streaming à la Kyocera native
# (192.168.1.10:443/ipp/print) qui parle IPP Everywhere nativement.
#
# IPPS a son port standard à 631 (RFC 8011) — macOS/Linux utilisent
# `ipps://print.amicalewifi.ch/printers/claudine` (port 631 par défaut).
# Windows (Microsoft IPP Class Driver) utilise `https://` sans port, ce qui
# résout sur 443 — on écoute donc les deux.
# Pour debug en CLI : `curl https://print.amicalewifi.ch:631/ipp/print`.
#
# Compat path : claudine-proxy accepte n'importe quel path (Director Go
# réécrit vers /ipp/print côté Kyocera), donc les installs existantes qui
# pointent sur /printers/claudine continuent de fonctionner.

(print_claudine) {
    encode gzip
    request_body {
        max_size 500MB
    }
    reverse_proxy 172.18.0.1:8000 {
        # IPP attend HTTP/1.1 chunked — pas de HTTP/2.
        transport http {
            versions 1.1
        }
    }
}

# Port 443 — Windows (https:// sans port explicite)
print.amicalewifi.ch {
    import print_claudine
}

# Port 631 — macOS / Linux / iOS (ipps:// ou https://:631)
https://print.amicalewifi.ch:631 {
    import print_claudine
}
