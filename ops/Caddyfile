{
    email hello@amicalewifi.ch
}

coworker.amicalewifi.ch {
    encode gzip
    reverse_proxy app:8081 {
        # During a deploy the `app` container is briefly unreachable while it
        # restarts (~25s). Instead of returning 502s to users, Caddy holds the
        # request for up to 45s, retrying the upstream every 500ms until it
        # answers. The user sees a slow page load instead of an error.
        lb_try_duration 45s
        lb_try_interval 500ms
    }
}

# Imprimante virtuelle Claudine — CUPS broker tourne sur le host (network_mode:
# host, port interne 6310) pour atteindre wg0 → Kyocera. Caddy termine TLS et
# reverse-proxy vers le gateway du bridge du projet (172.18.0.1, subnet pinné
# dans docker-compose.yml).
#
# IPPS a son port standard à 631 (RFC 8011) — macOS/Linux utilisent
# `ipps://print.amicalewifi.ch/printers/claudine` (port 631 par défaut).
# Windows (Microsoft IPP Class Driver) utilise `https://` sans port, ce qui
# résout sur 443 — on écoute donc les deux.
# Pour debug en CLI : `curl https://print.amicalewifi.ch:631/printers/claudine`.

(print_cups) {
    encode gzip
    request_body {
        max_size 500MB
    }
    # 6311 = ipp-shim (middleware Python qui absorbe l'op Microsoft 0x4000
    # bloquant l'install Windows 11) ; le shim proxifie tout le reste vers
    # cupsd sur 6310 en interne. Voir docker/cups-broker/ipp-shim.
    reverse_proxy 172.18.0.1:6311 {
        # CUPS / shim attendent HTTP/1.1 chunked pour IPP — pas de HTTP/2.
        transport http {
            versions 1.1
        }
    }
}

# Port 443 — Windows (https:// sans port explicite)
print.amicalewifi.ch {
    import print_cups
}

# Port 631 — macOS / Linux / iOS (ipps:// ou https://:631)
https://print.amicalewifi.ch:631 {
    import print_cups
}
